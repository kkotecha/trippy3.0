# Required
OPENAI_API_KEY=your-openai-api-key-here

# Arize Phoenix Cloud (Get credentials from https://app.arize.com)
ARIZE_SPACE_ID=your-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_PROJECT_NAME=trippy-decentralized

# Tavily Search API (Get from https://tavily.com)
TAVILY_API_KEY=your-tavily-api-key

# Google Maps Platform API (Places + Directions - $200/month free credit)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# App Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.5

# Frontend URL (for CORS) - Update this with your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app
